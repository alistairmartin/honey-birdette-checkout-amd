// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  // Local dev: file:dev.sqlite (set in .env). Production (Render): an absolute
  // path on the mounted persistent disk, e.g. file:/data/prod.sqlite.
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// One row per Shopify order that the reconciliation sweep found missing in Kibo.
// Sweeps upsert on (shop, shopifyOrderId), so re-running never duplicates a row.
// status: PENDING | EXISTS_IN_KIBO | REIMPORTED | REIMPORT_FAILED | IGNORED
model KiboFailedOrder {
  id               String   @id @default(cuid())
  shop             String
  shopifyOrderId   String
  shopifyOrderName String
  orderCreatedAt   DateTime
  detectedAt       DateTime @default(now())
  lastCheckedAt    DateTime @default(now())
  reason           String
  suggestion       String
  status           String   @default("PENDING")
  kiboOrderId      String?
  attempts         Int      @default(0)
  lastError        String?

  @@unique([shop, shopifyOrderId])
  @@index([shop, status])
}

// One row per template-copy run started from the Template copier page
// (app/routes/app.template-copier.jsx). A run copies N template files from one
// source shop/theme into one destination shop/theme, so a copy to three stores
// writes three rows sharing a `batchId` - that's what the history groups on.
// `filesJson` is the stringified array of per-file results
// ([{ filename, status, error }]), kept so the page can show exactly what landed.
// status: SUCCESS | PARTIAL | FAILED
model ThemeCopyLog {
  id              String   @id @default(cuid())
  // Shared by every row written by one press of the Copy button.
  batchId         String   @default("")
  // The store the app was open in when the copy ran. History and revert are
  // scoped to this, NOT to sourceShop - the source can be any store now, but the
  // copy still belongs to whoever was driving the app. Backfilled to sourceShop
  // for old rows via the default so pre-existing history still shows.
  embeddedShop    String   @default("")
  sourceShop      String
  sourceThemeId   String
  sourceThemeName String
  targetShop      String
  targetThemeId   String
  targetThemeName String
  targetThemeRole String
  fileCount       Int
  successCount    Int
  status          String
  filesJson       String
  // Per-image/video results ([{ filename, kind, status, error }]) when the run
  // also copied the media the templates reference into the destination's Files.
  imagesJson      String   @default("[]")
  // What the destination theme held for each of these filenames BEFORE the copy
  // ([{ filename, content }], content null when the copy created the file).
  // This is what Revert restores - without it, undoing means hunting through the
  // theme editor's version timeline by hand.
  previousJson    String   @default("[]")
  revertedAt      DateTime?
  error           String?
  copiedBy        String?
  createdAt       DateTime @default(now())

  @@index([sourceShop, createdAt])
  @@index([targetShop, createdAt])
  @@index([embeddedShop, createdAt])
  @@index([batchId])
}

// One row per saved Gift With Purchase config. The admin builder page writes
// these and, on every change, syncs the full set up to a shop metafield (read by
// the gift-with-purchase checkout extension) and the discount node metafield
// (read by the gift-with-purchase-discount function). `configJson` is the raw
// stringified config object.
model GwpAppV1Config {
  id         String   @id @default(cuid())
  shop       String
  name       String
  configJson String
  // GID of the automatic app discount this config owns (one discount per config,
  // each bound to the gift-with-purchase-discount function). Null until created.
  discountId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shop])
}
